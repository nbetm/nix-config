# vim: set ft=sh :
# shellcheck shell=bash disable=SC1091

# Exit if not interactive
[[ $- != *i* ]] && return

# ------------------------------------------------------------------------------
# LS_COLORS
# ------------------------------------------------------------------------------
# Set before ble.sh
if [[ -f "${HOME}/.dir_colors" ]]; then
    eval "$(dircolors -b "${HOME}/.dir_colors")"
fi

# ------------------------------------------------------------------------------
# ble.sh - Bash Line Editor (attach early)
# ------------------------------------------------------------------------------

# Prefer the nix-managed package (provides blesh-share); fall back to a manual
# install (Debian/Ubuntu) under XDG_DATA_HOME.
if command -v blesh-share &>/dev/null; then
    _ble_sh="$(blesh-share)/ble.sh"
elif [[ -f "${XDG_DATA_HOME:-$HOME/.local/share}/blesh/ble.sh" ]]; then
    _ble_sh="${XDG_DATA_HOME:-$HOME/.local/share}/blesh/ble.sh"
fi
if [[ -n "${_ble_sh:-}" ]]; then
    # shellcheck disable=SC1090
    source "$_ble_sh" --attach=none
fi

# ------------------------------------------------------------------------------
# Shell Options
# ------------------------------------------------------------------------------

# Navigation
shopt -s autocd      # cd into directory by typing its name
shopt -s cdspell     # Autocorrect typos in cd
shopt -s dirspell    # Autocorrect directory names during completion
shopt -s cdable_vars # cd into variable values

# Globbing
shopt -s extglob    # Extended pattern matching
shopt -s globstar   # ** matches all files and directories recursively
shopt -s nocaseglob # Case-insensitive globbing
shopt -s dotglob    # Include hidden files in glob

# History
shopt -s histappend # Append to history instead of overwriting
shopt -s cmdhist    # Save multi-line commands as single entry

# Misc
shopt -s checkwinsize            # Update LINES and COLUMNS after each command
shopt -s no_empty_cmd_completion # Don't complete on empty line

# ------------------------------------------------------------------------------
# Tool Integrations
# ------------------------------------------------------------------------------

# FZF (ble.sh loads its own fzf integration via blesh-contrib)
if [[ -z "${BLE_VERSION:-}" ]] && command -v fzf &>/dev/null; then
    eval "$(fzf --bash)"
fi

# Starship prompt
if command -v starship &>/dev/null; then
    eval "$(starship init bash)"
fi

# ------------------------------------------------------------------------------
# Bash Completion
# ------------------------------------------------------------------------------

# nix-darwin/NixOS handle bash completion via programs.bash.completion.enable
if [[ ! -d /run/current-system ]] && [[ -f /usr/share/bash-completion/bash_completion ]]; then
    source /usr/share/bash-completion/bash_completion
fi

# AWS (not in bash-completion, uses built-in completer)
command -v aws_completer &>/dev/null && complete -C aws_completer aws

# ------------------------------------------------------------------------------
# Shared Shell Config
# ------------------------------------------------------------------------------

if [[ -d "${XDG_DATA_HOME}/shell" ]]; then
    for file in "${XDG_DATA_HOME}"/shell/*.sh; do
        # shellcheck disable=SC1090
        [[ -f "$file" ]] && source "$file"
    done
fi

# ------------------------------------------------------------------------------
# Alias Completions
# ------------------------------------------------------------------------------
# Completions don't inherit through aliases. complete-alias expands the alias
# into COMP_LINE and dispatches to the real command's completion.
if command -v complete_alias &>/dev/null; then
    # shellcheck disable=SC1090
    source "$(command -v complete_alias)"
    complete -F _complete_alias g t s tf j ass asd
fi

# ------------------------------------------------------------------------------
# Zoxide (must be near the end per zoxide docs)
# ------------------------------------------------------------------------------

if command -v zoxide &>/dev/null; then
    eval "$(zoxide init bash)"
fi

# ------------------------------------------------------------------------------
# ble.sh - Attach (must be at the end)
# ------------------------------------------------------------------------------

# shellcheck disable=SC2154
[[ ! ${BLE_VERSION-} ]] || ble-attach
